# mycel config
# no default model is shipped on purpose. uncomment exactly one provider block
# and one model block, then set default_model. mycel refuses to start without it
# and tells you exactly what is missing.

# default_model = "kimi-code/k3"
default_permission_mode = "manual"
telemetry = false

