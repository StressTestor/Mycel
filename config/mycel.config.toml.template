# --- immunity gate (fail-closed) --------------------------------------------
# blocks tool calls matching active antibodies in the substrate, AND blocks any
# Write/Edit/MCP-path file write that targets the gate's own binary dir, installed
# config, or substrate (the compiled protected-path floor).
#
# matcher is catch-all ("") on purpose: the gate governs EVERY tool, not just
# Bash. the whole-toolset coupling is deliberate - a missing OR corrupt substrate
# db (deleted, 0-byte, truncated, non-sqlite, or empty-schema) now fail-closed
# BLOCKS every routed tool (Read/Grep included), because it means the guard was
# disarmed. gate crashed, hung, missing db, or integrity-broken db = BLOCKED.
# that is the point.
#
# sealed same-session self-disarm: the Write/Edit/MCP-path file write over the
# gate binary/config/substrate (floor), and the truncated/empty db (strict
# read-only open). NOT sealed: a Bash COMMAND that writes a protected path
# (cp/tee/redirect over ~/.mycel/bin/mycel-gate) - that needs structured shell
# parsing and is a separate future bet, same as the MCP-non-path-field residual.
[[hooks]]
event = "PreToolUse"
matcher = ""
command = "$HOME/.mycel/bin/mycel-gate"
timeout = 10
fail_mode = "closed"

# --- immunity learning loop (observe -> ingest) -----------------------------
# every failed/blocked tool call is captured to the substrate audit log, so
# the substrate learns from what goes wrong. observation-only (never blocks,
# always exits 0). candidates stay INERT until you promote them with
# `mycel-substrate antibody-add`, so nothing auto-activates.
[[hooks]]
event = "PostToolUseFailure"
matcher = ""
command = "$HOME/.mycel/bin/mycel-observe"
timeout = 10

# at session end, fold the captured failures into antibody candidates.
# ingest records the events and surfaces candidates; it never activates them.
[[hooks]]
event = "SessionEnd"
matcher = ""
command = "$HOME/.mycel/bin/mycel-substrate ingest --db $HOME/.mycel/substrate/mycel.db --jsonl $HOME/.mycel/substrate/audit.jsonl"
timeout = 30

