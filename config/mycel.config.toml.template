# --- immunity gate (fail-closed) --------------------------------------------
# blocks shell commands matching active antibodies in the substrate.
# gate crashed, hung, or missing db = command BLOCKED. that is the point.
[[hooks]]
event = "PreToolUse"
matcher = "Bash"
command = "$HOME/.mycel/bin/mycel-gate"
timeout = 10
fail_mode = "closed"

